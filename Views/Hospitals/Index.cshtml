@{
    ViewData["Title"] = "Manage Hospitals";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="text-info">
        <i class="bi bi-building-gear"></i> Manage Hospitals
    </h1>
    <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#hospitalModal"
            onclick="openCreateForm()">
        <i class="bi bi-plus-lg"></i> Add Hospital
    </button>
</div>

<p class="text-secondary">
    Hospitals registered here are used by the routing algorithm in your Flask backend
    when selecting where to send a crash victim. Capacity score (0–1) influences
    which hospital is preferred — higher = more available beds.
</p>

<div class="card bg-dark">
    <div class="card-body p-0">
        <table class="table table-dark table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Latitude</th>
                    <th>Longitude</th>
                    <th>Capacity</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody id="hospitals-tbody">
                <tr>
                    <td colspan="6" class="text-center text-secondary py-4">Loading...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@* ── Add/Edit Modal ──────────────────────────────────────────────────
   Bootstrap modal — hidden by default, shown when data-bs-toggle clicks happen.
*@
<div class="modal fade" id="hospitalModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content bg-dark border-info">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title" id="modal-title">Add Hospital</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="form-error" class="alert alert-danger d-none"></div>

                <div class="mb-3">
                    <label class="form-label">Hospital ID</label>
                    <input type="text" id="form-id" class="form-control" placeholder="e.g. H-003">
                    <small class="text-secondary">Unique short code. Cannot be changed after creation.</small>
                </div>

                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input type="text" id="form-name" class="form-control" placeholder="Jordan Hospital">
                </div>

                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label">Latitude</label>
                        <input type="number" step="0.0001" id="form-lat" class="form-control" placeholder="31.9539">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Longitude</label>
                        <input type="number" step="0.0001" id="form-lng" class="form-control" placeholder="35.9106">
                    </div>
                </div>

                <div class="mb-3 mt-3">
                    <label class="form-label d-flex justify-content-between">
                        <span>Capacity score</span>
                        <span id="capacity-readout" class="text-info">1.0</span>
                    </label>
                    <input type="range" id="form-capacity" class="form-range"
                           min="0" max="1" step="0.05" value="1">
                    <small class="text-secondary">0 = full / closed, 1 = lots of free beds.</small>
                </div>
            </div>
            <div class="modal-footer border-top border-secondary">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-info" id="save-btn">Save</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
<script>
    // Only management + admin can manage hospitals. ER staff get bounced out.
    VitalLinkAuth.requireAuth(["management", "admin"]).then(() => init());

    let editingId = null;          // null = creating new; non-null = editing existing
    let modalInstance = null;

    function init() {
        modalInstance = new bootstrap.Modal(document.getElementById("hospitalModal"));

        // Live update the readout next to the slider.
        const capInput = document.getElementById("form-capacity");
        capInput.addEventListener("input", () => {
            document.getElementById("capacity-readout").textContent =
                parseFloat(capInput.value).toFixed(2);
        });

        document.getElementById("save-btn").addEventListener("click", saveHospital);

        // Listen on /hospitals — re-render every time something changes.
        VitalLinkAuth.db.ref("/hospitals").on("value", snap => {
            renderTable(snap.val() || {});
        });
    }

    function renderTable(hospitals) {
        const tbody = document.getElementById("hospitals-tbody");
        const list = Object.entries(hospitals);
        if (list.length === 0) {
            tbody.innerHTML = `<tr><td colspan="6" class="text-center text-secondary py-4">
                No hospitals yet. Click <strong>Add Hospital</strong> to add one.</td></tr>`;
            return;
        }
        tbody.innerHTML = list.map(([id, h]) => `
            <tr>
                <td><code class="text-info">${escapeHtml(id)}</code></td>
                <td>${escapeHtml(h.name || "—")}</td>
                <td>${(h.lat || 0).toFixed(4)}</td>
                <td>${(h.lng || 0).toFixed(4)}</td>
                <td style="width: 200px;">
                    <div class="progress bg-secondary" style="height: 18px;">
                        <div class="progress-bar bg-info" style="width: ${Math.round((h.capacity_score || 0) * 100)}%">
                            ${Math.round((h.capacity_score || 0) * 100)}%
                        </div>
                    </div>
                </td>
                <td class="text-end">
                    <button class="btn btn-sm btn-outline-info"
                            onclick="openEditForm('${escapeJs(id)}')">
                        <i class="bi bi-pencil"></i> Edit
                    </button>
                    <button class="btn btn-sm btn-outline-danger"
                            onclick="deleteHospital('${escapeJs(id)}', '${escapeJs(h.name || id)}')">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </td>
            </tr>
        `).join("");
    }

    // ── Open the form in CREATE mode ───────────────────────────────────
    window.openCreateForm = function () {
        editingId = null;
        document.getElementById("modal-title").textContent = "Add Hospital";
        document.getElementById("form-id").value = "";
        document.getElementById("form-id").disabled = false;
        document.getElementById("form-name").value = "";
        document.getElementById("form-lat").value = "";
        document.getElementById("form-lng").value = "";
        document.getElementById("form-capacity").value = "1";
        document.getElementById("capacity-readout").textContent = "1.00";
        hideError();
    };

    // ── Open the form in EDIT mode ─────────────────────────────────────
    window.openEditForm = async function (id) {
        editingId = id;
        const snap = await VitalLinkAuth.db.ref("/hospitals/" + id).once("value");
        const h = snap.val() || {};
        document.getElementById("modal-title").textContent = "Edit Hospital — " + id;
        document.getElementById("form-id").value = id;
        document.getElementById("form-id").disabled = true;     // don't allow ID change
        document.getElementById("form-name").value = h.name || "";
        document.getElementById("form-lat").value = h.lat || "";
        document.getElementById("form-lng").value = h.lng || "";
        document.getElementById("form-capacity").value = h.capacity_score ?? 1;
        document.getElementById("capacity-readout").textContent =
            (h.capacity_score ?? 1).toFixed(2);
        hideError();
        modalInstance.show();
    };

    // ── Save handler (create or update) ────────────────────────────────
    async function saveHospital() {
        hideError();
        const id = document.getElementById("form-id").value.trim();
        const name = document.getElementById("form-name").value.trim();
        const lat = parseFloat(document.getElementById("form-lat").value);
        const lng = parseFloat(document.getElementById("form-lng").value);
        const cap = parseFloat(document.getElementById("form-capacity").value);

        if (!id) return showError("Hospital ID is required.");
        if (!name) return showError("Name is required.");
        if (isNaN(lat) || lat < -90 || lat > 90)
            return showError("Latitude must be a number between -90 and 90.");
        if (isNaN(lng) || lng < -180 || lng > 180)
            return showError("Longitude must be a number between -180 and 180.");

        const data = { name, lat, lng, capacity_score: cap };

        try {
            // .set() overwrites the whole node at /hospitals/{id}. Same as PUT in REST.
            await VitalLinkAuth.db.ref("/hospitals/" + id).set(data);
            modalInstance.hide();
        } catch (err) {
            showError("Save failed: " + err.message);
        }
    }

    // ── Delete handler ─────────────────────────────────────────────────
    window.deleteHospital = async function (id, name) {
        if (!confirm(`Delete hospital "${name}" (${id})? This cannot be undone.`)) return;
        try {
            await VitalLinkAuth.db.ref("/hospitals/" + id).remove();
        } catch (err) {
            alert("Delete failed: " + err.message);
        }
    };

    function showError(msg) {
        const el = document.getElementById("form-error");
        el.textContent = msg;
        el.classList.remove("d-none");
    }
    function hideError() {
        document.getElementById("form-error").classList.add("d-none");
    }

    function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, c => ({
            "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;"
        }[c]));
    }
    // Slightly different: safe to drop into a JS string literal inside a quoted attribute.
    function escapeJs(s) {
        return String(s).replace(/['"\\]/g, c => "\\" + c);
    }
</script>
}
